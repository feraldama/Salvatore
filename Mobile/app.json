{
  "expo": {
    "name": "JWF Mobile",
    "slug": "Mobile",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "JWF Mobile registra tu ubicación durante un viaje activo para el control de flota. El registro sigue cuando la app está en background o el celu está bloqueado, y se detiene al cerrar el viaje.",
        "NSLocationWhenInUseUsageDescription": "JWF Mobile usa tu ubicación para asignarte incidencias cercanas y registrar la ubicación de tus marcaciones de asistencia."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./android/app/google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "package": "com.anonymous.Mobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "JWF Mobile necesita acceso a la galería para adjuntar fotos a incidencias y marcaciones.",
          "cameraPermission": "JWF Mobile necesita acceso a la cámara para tomar fotos de reparación y selfies de marcación de asistencia."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2D7A4F",
          "defaultChannel": "incidencias"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "JWF Mobile registra tu ubicación durante un viaje activo. El tracking sigue funcionando con la app en background o el celu bloqueado, y se detiene cuando cerrás el viaje.",
          "locationWhenInUsePermission": "JWF Mobile usa tu ubicación para asignarte incidencias cercanas y para registrar la ubicación de tus marcaciones de asistencia.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "05714990-6158-4993-8fa1-ac9610e278c5"
      }
    },
    "owner": "faldamajwf",
    "runtimeVersion": "1",
    "updates": {
      "url": "https://u.expo.dev/05714990-6158-4993-8fa1-ac9610e278c5"
    }
  }
}
