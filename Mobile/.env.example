# Integración con Salvatore: un solo backend sirve los 3 clientes de la app.
# Apuntar las tres URLs al MISMO backend Salvatore (sufijo /api obligatorio).
# En device físico usar la IP de la máquina que corre el backend, NO localhost.
#
# El backend Salvatore corre por defecto en el puerto 3023 (api/.env -> PORT).
# Sólo está implementado el módulo de flota (ERP); CMS/CRM apuntan al mismo
# backend para que la app levante, pero esos módulos aún no tienen endpoints.

EXPO_PUBLIC_ERP_API_URL=http://192.168.0.17:3023/api
EXPO_PUBLIC_CMS_API_URL=http://192.168.0.17:3023/api
EXPO_PUBLIC_CRM_API_URL=http://192.168.0.17:3023/api
